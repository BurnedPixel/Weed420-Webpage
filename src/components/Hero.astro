<section id="home" class="relative h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/60 via-transparent to-[#0a0a0a] z-10"></div>
  
  <div class="absolute inset-0 bg-[url('/images/caracas-portrait.png')] bg-cover bg-center opacity-40"></div>
  
  <div class="relative z-20 text-center px-6">
    <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter uppercase mb-4">
      <span class="text-[#f5f5f5]">weed</span><span class="text-[#dc2626]">420</span>
    </h1>
    <p class="text-lg md:text-xl font-light tracking-[0.3em] uppercase text-[#f5f5f5]/60 mb-12">
