---
interface Props {
  src: string;
  placeholder?: string;
  alt: string;
  priority?: boolean;
  sizes?: string;
  class?: string;
  style?: string;
  loadingClass?: string;
}

const {
  src,
  placeholder,
  alt,
  priority = false,
  sizes = "(max-width: 768px) 100vw, 50vw",
  class: className = "",
  style = "",
  loadingClass = "opacity-0"
} = Astro.props;

const wrapperId = `pw-${Math.random().toString(36).slice(2, 9)}`;
const hasPositionClass = className && /^\s*(absolute|fixed|relative|static)\s/.test(className);
---

<div
  id={wrapperId}
  class:list={["progressive-image-wrapper overflow-hidden", className]}
  style={style}
>
  <img
    src={placeholder || src}
    alt=""
    class="progressive-placeholder absolute inset-0 w-full h-full object-cover blur-xl scale-110 opacity-100 transition-opacity duration-500 ease-out"
    aria-hidden="true"
  />
  <img
    src={src}
    alt={alt}
    loading={priority ? "eager" : "lazy"}
    decoding={priority ? "sync" : "async"}
    fetchpriority={priority ? "high" : "auto"}
    sizes={sizes}
    class:list={["progressive-target absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-out", loadingClass]}
  />
</div>

<script define:vars={{ wrapperId, placeholder }}>
(function() {
  const wrapper = document.getElementById(wrapperId);
  if (!wrapper) return;
  
  const target = wrapper.querySelector('.progressive-target');
  const placeholder = wrapper.querySelector('.progressive-placeholder');
  if (!target || !placeholder) return;

  const handleLoad = () => {
    target.classList.remove('opacity-0');
    placeholder.classList.add('opacity-0');
    target.removeEventListener('load', handleLoad);
  };

  if (target.complete) {
    handleLoad();
  } else {
    target.addEventListener('load', handleLoad);
  }
})();
</script>

<style>
.progressive-image-wrapper {
  will-change: opacity;
}
.progressive-target {
  z-index: 1;
}
</style>