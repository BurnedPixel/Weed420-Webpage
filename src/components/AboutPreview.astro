---
const images = [
  { src: '/images/carousel/01.jpg', placeholder: '/images/placeholders/01.lqip.webp' },
  { src: '/images/carousel/02.jpg', placeholder: '/images/placeholders/02.lqip.webp' },
  { src: '/images/carousel/03.jpg', placeholder: '/images/placeholders/03.lqip.webp' },
  { src: '/images/carousel/04.jpg', placeholder: '/images/placeholders/04.lqip.webp' },
  { src: '/images/carousel/05.jpg', placeholder: '/images/placeholders/05.lqip.webp' },
  { src: '/images/carousel/06.jpg', placeholder: '/images/placeholders/06.lqip.webp' },
  { src: '/images/carousel/07.jpg', placeholder: '/images/placeholders/07.lqip.webp' },
];

const shuffled = [...images].sort(() => Math.random() - 0.5);
const firstIndex = Math.floor(Math.random() * shuffled.length);
---

<section id="bio" class="py-24 px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 md:gap-20 items-center">
    <div class="relative" style="filter: drop-shadow(0 0 40px rgba(255,255,255,0.06)) drop-shadow(0 0 80px rgba(255,255,255,0.03));">
      <div class="aspect-[4/5] bg-bg-card overflow-hidden cursor-pointer" id="carousel-frame" data-first={firstIndex}>
        {shuffled.map((img, i) => (
          <div
            class="carousel-item absolute inset-0 transition-opacity duration-1000 ease-in-out"
            data-index={i}
            style={`opacity: ${i === firstIndex ? 1 : 0};`}
          >
            <img
              src={img.src}
              placeholder={img.placeholder}
              alt="weed420"
              class="carousel-img w-full h-full object-cover grayscale"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
      <div class="absolute inset-0 border border-accent-muted pointer-events-none"></div>
    </div>

    <div>
      <h2 class="text-xs tracking-[0.3em] uppercase text-accent mb-4">About</h2>
      <h3 class="text-2xl md:text-3xl font-semibold uppercase mb-8">Epic Collage<br/><span class="text-text-muted">From Venezuela</span></h3>
      <p class="text-text-muted text-sm leading-relaxed mb-8 max-w-md">
        weed420 is an experimental sound-collage collective from Valencia, Venezuela, exploring memory, politics, and the experience of uprooting. Blending noise, lo-fi, and maximalist vaporwave, they fuse somber cloud-rap and ambient textures with 2000s perreo and salsa. Through guitars, synths, and processed vocals, they connect chopped &lsquo;n&rsquo; screwed trap with deep-rooted Latin American influences, creating hyper-emo, atmospheric reinterpretations of club music filled with joyful abandon.
      </p>
      <p class="text-text-dim text-sm mb-8 max-w-md">
        Their conceptual depth peaks in Amor de Encava, an album inspired by customized Venezuelan transit buses. Weaving reggaet&oacute;n, salsa ba&uacute;l, and pop memories, it maps a sonic cartography of daily life and systemic catastrophe. Live, weed420 deploys this radical collage approach, jumping between overwhelming percussion and hypnotic abstraction. Amid political turmoil, their immersive performances position rhythm as a definitive space for resistance and memory.
      </p>
      <a href="#music" class="inline-flex items-center gap-3 text-sm tracking-wider uppercase text-text border border-border-light px-6 py-3 hover:bg-accent hover:border-accent transition-all">
        Learn More
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes kenburns {
    0% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(1.08) translate(-1%, -0.5%); }
    100% { transform: scale(1.04) translate(0.5%, 1%); }
  }

  .carousel-item {
    animation: kenburns 15s ease-in-out infinite alternate;
    animation-play-state: paused;
  }

  .carousel-item.active {
    animation-play-state: running;
  }

  .carousel-item img {
    will-change: opacity, transform;
  }
</style>

<script>
  (function() {
    const frame = document.getElementById('carousel-frame');
    if (!frame) return;

    const items = frame.querySelectorAll('.carousel-item');
    if (!items.length) return;

    let current = parseInt(frame.dataset.first) || 0;
    let timer: ReturnType<typeof setInterval>;

    items.forEach((item, i) => {
      if (i === current) {
        item.classList.add('active');
      }
    });

    function show(index: number) {
      items.forEach((item, i) => {
        const el = item as HTMLElement;
        if (i === index) {
          el.style.opacity = '1';
          item.classList.add('active');
        } else {
          el.style.opacity = '0';
          item.classList.remove('active');
        }
      });
      current = index;
    }

    function next() {
      show((current + 1) % items.length);
    }

    frame.addEventListener('click', next);
    frame.addEventListener('mouseenter', () => clearInterval(timer));
    frame.addEventListener('mouseleave', () => {
      timer = setInterval(next, 6000);
    });

    timer = setInterval(next, 6000);

    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(() => {
        items.forEach(item => {
          const img = item.querySelector('img');
          if (img) {
            (img as HTMLImageElement).loading = 'lazy';
          }
        });
      }, { timeout: 3000 });
    }
  })();
</script>