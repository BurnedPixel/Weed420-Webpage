---
import { SITE } from '../data/constants';
import { fetchTourDates, type TourEntry } from '../data/tour';
import TourDateRow from './TourDateRow.astro';

let entries: TourEntry[] = [];
let error: string | null = null;

try {
  entries = await fetchTourDates(SITE.googleSheetBaseUrl);
} catch (e) {
  console.error('TourDates fetch failed:', e);
  error = 'Unable to load tour dates';
}
---

<section id="tour" class="py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-section uppercase text-accent mb-10">Tour Dates</h2>

    <div class="space-y-0 text-left">
      {error && (
        <div class="text-text-dim py-8">
          <p class="text-sm tracking-wider">{error}</p>
        </div>
      )}

      {!error && entries.length === 0 && (
        <div class="text-text-dim py-4">
          <p class="text-sm">No upcoming tour dates</p>
        </div>
      )}

      {!error && entries.map(d => (
        <TourDateRow date={d.date} venue={d.venue} city={d.city} link={d.link || undefined} />
      ))}
    </div>
  </div>
</section>
