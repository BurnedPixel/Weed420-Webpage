---
import type { Release } from '../data/discography';

interface Props {
  release: Release;
  compact?: boolean;
  floatDelay?: number;
}

const { release, compact = false, floatDelay } = Astro.props;

const wrapperClass = compact
  ? 'group relative aspect-square bg-bg-card overflow-hidden hover:border hover:border-accent-muted transition-colors'
  : 'group relative aspect-square bg-bg-card overflow-hidden border border-border hover:border-accent/50 transition-all duration-300 hover:-translate-y-1';

const widthStyle = compact
  ? 'width: clamp(80px, 15vw, 140px);'
  : 'width: clamp(140px, 25vw, 260px);';

const animationStyle = !compact && floatDelay !== undefined
  ? `animation: float 3s ease-in-out infinite; animation-delay: ${floatDelay}s;`
  : '';

const imgClass = compact
  ? 'w-full h-full object-cover opacity-50 group-hover:opacity-70 transition-opacity duration-300'
  : 'w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-500';

const overlayClass = compact
  ? 'text-2xs tracking-wider uppercase text-text border border-text-dim px-2 py-0.5'
  : 'text-sm tracking-wider uppercase text-text border border-text px-3 py-1.5';
---

<a
  href={release.link}
  target="_blank"
  rel="noopener noreferrer"
  class={wrapperClass}
  style={`${widthStyle} ${animationStyle}`}
>
  <picture>
    <source srcset={release.image.replace('.jpg', '.webp')} type="image/webp" />
    <img
      src={release.image}
      alt={release.title}
      loading="lazy"
      decoding="async"
      class={imgClass}
    />
  </picture>
  <div class={compact ? 'absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-50' : 'absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-60'}></div>
  <div class={compact ? 'absolute bottom-0 left-0 right-0 p-1.5' : 'absolute bottom-0 left-0 right-0 p-3'}>
    {compact ? (
      <>
        <p class="text-2xs text-accent/60 tracking-wider mb-0.5">{release.year}</p>
        <h3 class="text-2xs font-medium uppercase leading-tight truncate">{release.title}</h3>
      </>
    ) : (
      <>
        <p class="text-xs text-accent tracking-widest mb-0.5">{release.year}</p>
        <h3 class="text-sm font-semibold uppercase leading-tight">{release.title}</h3>
      </>
    )}
  </div>
  <div class={compact ? 'absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-bg/60' : 'absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-bg/60'}>
    <span class={overlayClass}>
      {compact ? '→' : 'Listen'}
    </span>
  </div>
</a>
