---
const links = [
  { href: '#home', label: 'Home' },
  { href: '#bio', label: 'Bio' },
  { href: '#music', label: 'Music' },
  { href: '#video', label: 'Video' },
  { href: '#tour', label: 'Tour' },
  { href: '#booking', label: 'Booking' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-widest uppercase text-[#f5f5f5] hover:text-[#dc2626] transition-colors">
      weed420
    </a>
    
    <ul class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <li>
          <a href={link.href} class="text-sm tracking-wider uppercase text-[#f5f5f5]/70 hover:text-[#dc2626] transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    
    <button class="md:hidden text-[#f5f5f5]" id="menu-toggle" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  
  <div class="md:hidden hidden absolute top-full left-0 right-0 bg-[#0a0a0a]/95 backdrop-blur-md border-t border-[#f5f5f5]/10" id="mobile-menu">
    <ul class="px-6 py-4 space-y-4">
      {links.map(link => (
        <li>
          <a href={link.href} class="block text-sm tracking-wider uppercase text-[#f5f5f5]/70 hover:text-[#dc2626] transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-[#f5f5f5]/10');
    } else {
      navbar?.classList.remove('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-[#f5f5f5]/10');
    }
  });
  
  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>