---
import { NAV_LINKS } from '../data/constants';
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-base font-semibold tracking-widest uppercase text-text hover:text-accent transition-colors">
      weed420
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {NAV_LINKS.map(link => (
        <li>
          <a href={link.href} class="text-sm tracking-wider uppercase text-text-muted hover:text-accent transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button class="md:hidden text-text" id="menu-toggle" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div class="md:hidden hidden absolute top-full left-0 right-0 bg-bg/95 backdrop-blur-md border-t border-border" id="mobile-menu">
    <ul class="px-6 py-4 space-y-4">
      {NAV_LINKS.map(link => (
        <li>
          <a href={link.href} class="block text-sm tracking-wider uppercase text-text-muted hover:text-accent transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  const onScroll = () => {
    navbar?.classList.toggle('bg-bg/95', window.scrollY > 50);
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('load', onScroll);

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
