---
const socials = [
  { name: 'Instagram', url: 'https://instagram.com/weed420', icon: 'instagram' },
  { name: 'YouTube', url: 'https://youtube.com/@weed420', icon: 'youtube' },
];

const contactEmail = 'booking@weed420.com';
---

<footer id="booking" class="py-24 px-6 bg-[#050505]">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-xs tracking-[0.3em] uppercase text-[#dc2626] mb-4">Contact</h2>
      <p class="text-3xl md:text-4xl font-bold uppercase mb-4">Booking & Inquiries</p>
      <a href={`mailto:${contactEmail}`} class="text-lg text-[#f5f5f5]/60 hover:text-[#dc2626] transition-colors">
        {contactEmail}
      </a>
    </div>
    
    <div class="mb-16">
      <p class="text-xs tracking-[0.3em] uppercase text-[#f5f5f5]/30 mb-6 text-center">Follow</p>
      <div class="flex justify-center gap-8">
        {socials.map(social => (
          <a 
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#f5f5f5]/40 hover:text-[#dc2626] transition-colors"
            aria-label={social.name}
          >
            {social.icon === 'instagram' && (
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.056 6.78 6.418 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.95-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.441s.645 1.441 1.441 1.441 1.441-.645 1.441-1.441-.645-1.441-1.441-1.441z"/>
              </svg>
            )}
            {social.icon === 'youtube' && (
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
    
    <div class="text-center pt-8 border-t border-[#f5f5f5]/10">
      <p class="text-xs text-[#f5f5f5]/30 tracking-wider">
        &copy; {new Date().getFullYear()} weed420. All rights reserved.
      </p>
    </div>
  </div>
</footer>