---
import { SOCIALS, SITE } from '../data/constants';
import { iconDefs } from '../data/icons';

const contactEmail = SITE.contactEmail;
---

<footer id="booking" class="py-24 px-6 bg-bg-alt">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-xs tracking-section uppercase text-accent mb-4">Contact</h2>
      <p class="text-2xl font-semibold uppercase mb-4">Booking & Inquiries</p>
      <a href={`mailto:${contactEmail}`} class="text-sm text-text-muted hover:text-accent transition-colors">
        {contactEmail}
      </a>
    </div>

    <div class="mb-16">
      <p class="text-xs tracking-section uppercase text-text-faint mb-6 text-center">Follow</p>
      <div class="flex justify-center gap-8">
        {SOCIALS.map(social => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-dim hover:text-accent transition-colors"
            aria-label={social.name}
          >
            <svg class="w-6 h-6" viewBox={iconDefs[social.icon].viewBox} fill="currentColor">
              <path d={iconDefs[social.icon].path} />
            </svg>
          </a>
        ))}
      </div>
    </div>

    <div class="text-center pt-8 border-t border-border">
      <p class="text-xs text-text-faint tracking-wider">
        &copy; {new Date().getFullYear()} weed420. All rights reserved.
      </p>
    </div>
  </div>
</footer>
