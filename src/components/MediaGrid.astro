---
import { albums, mixtapes, djmixes, live, eps, others } from '../data/discography';
import ProgressiveImage from './ProgressiveImage.astro';

const sections = [
  { label: 'Mixtapes', items: mixtapes },
  { label: 'DJ Mixes', items: djmixes },
  { label: 'Live', items: live },
  { label: 'EP', items: eps },
  { label: 'Other Artists', items: others },
];

const floatDelays = [0, 0.8, 1.6];

const placeholderFor = (imagePath: string) =>
  imagePath.replace('/albums/', '/placeholders/').replace('.jpg', '.lqip.webp');
---

<section id="discography" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-xs tracking-[0.3em] uppercase text-accent mb-12 text-center">Discography</h2>

    <div class="flex flex-wrap justify-center gap-4 md:gap-8 mb-16">
      {albums.map((release, i) => (
        <a
          href={release.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative aspect-square bg-bg-card overflow-hidden border border-border hover:border-accent/50 transition-all duration-300 hover:-translate-y-1"
          style={`width: clamp(140px, 25vw, 260px); animation: float 3s ease-in-out infinite; animation-delay: ${floatDelays[i]}s;`}
        >
          <ProgressiveImage
            src={release.image}
            placeholder={placeholderFor(release.image)}
            alt={release.title}
            priority={false}
            sizes="(max-width: 768px) 50vw, 25vw"
            class="w-full h-full"
            loadingClass="opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-60"></div>
          <div class="absolute bottom-0 left-0 right-0 p-3">
            <p class="text-xs text-accent tracking-widest mb-0.5">{release.year}</p>
            <h3 class="text-sm font-semibold uppercase leading-tight">{release.title}</h3>
          </div>
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-bg/60">
            <span class="text-sm tracking-wider uppercase text-text border border-text px-3 py-1.5">
              Listen
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-x-6 gap-y-3">
      {sections.map(section => (
        <div class="inline-flex items-start gap-2">
          <h3 class="text-[10px] tracking-[0.25em] uppercase text-text bg-text/5 px-1 py-1.5 flex items-center justify-center" style="writing-mode: vertical-rl; height: clamp(80px, 15vw, 140px);">{section.label}</h3>
          {section.items.map(release => (
            <a
              href={release.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative aspect-square bg-bg-card overflow-hidden hover:border hover:border-accent-muted transition-colors"
              style="width: clamp(80px, 15vw, 140px);"
            >
              <ProgressiveImage
                src={release.image}
                placeholder={placeholderFor(release.image)}
                alt={release.title}
                priority={false}
                sizes="(max-width: 768px) 25vw, 15vw"
                class="w-full h-full"
                loadingClass="opacity-50 group-hover:opacity-70 transition-opacity duration-300"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-50"></div>
              <div class="absolute bottom-0 left-0 right-0 p-1.5">
                <p class="text-[10px] text-accent/60 tracking-wider mb-0.5">{release.year}</p>
                <h3 class="text-[10px] font-medium uppercase leading-tight truncate">{release.title}</h3>
              </div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-bg/60">
                <span class="text-[10px] tracking-wider uppercase text-text border border-text-dim px-2 py-0.5">
                  &rarr;
                </span>
              </div>
            </a>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>