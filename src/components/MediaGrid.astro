---
import AlbumCard from './AlbumCard.astro';
import { albums, mixtapes, djmixes, live, eps, others } from '../data/discography';

const sections = [
  { label: 'Mixtapes', items: mixtapes },
  { label: 'DJ Mixes', items: djmixes },
  { label: 'Live', items: live },
  { label: 'EP', items: eps },
  { label: 'Other Artists', items: others },
];

const floatDelays = [0, 0.8, 1.6];
---

<section id="discography" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-xs tracking-section uppercase text-accent mb-12 text-center">Discography</h2>

    <div class="flex flex-wrap justify-center gap-4 md:gap-8 mb-16">
      {albums.map((release, i) => (
        <AlbumCard release={release} floatDelay={floatDelays[i]} />
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-x-6 gap-y-3">
      {sections.map(section => (
        <div class="inline-flex items-start gap-2">
          <h3
            class="text-2xs tracking-label uppercase text-text bg-text/5 px-1 py-1.5 flex items-center justify-center writing-rl"
            style="height: clamp(80px, 15vw, 140px);"
          >
            {section.label}
          </h3>
          {section.items.map(release => (
            <AlbumCard release={release} compact />
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
