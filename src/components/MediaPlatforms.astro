---
import { PLATFORMS } from '../data/constants';
import SpotifySvg from '../../assets/spotify.svg?raw';
import BandcampSvg from '../../assets/bandcamp.svg?raw';
import SoundCloudSvg from '../../assets/soundcloud.svg?raw';
import AppleMusicSvg from '../../assets/applemusic.svg?raw';
import DeezerSvg from '../../assets/deezer.svg?raw';
import TidalSvg from '../../assets/tidal.svg?raw';
import YouTubeMusicSvg from '../../assets/youtubeMusic.svg?raw';

const svgMap = {
  bandcamp: BandcampSvg,
  spotify: SpotifySvg,
  soundcloud: SoundCloudSvg,
  applemusic: AppleMusicSvg,
  deezer: DeezerSvg,
  tidal: TidalSvg,
  youtubemusic: YouTubeMusicSvg,
};
---

<section id="music" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-xs tracking-[0.3em] uppercase text-accent mb-12 text-center">Listen</h2>

    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
      {PLATFORMS.map(platform => (
        <a
          href={platform.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-3 text-text-dim hover:text-text transition-all duration-300"
        >
          <div class="w-20 h-20 flex items-center justify-center border border-border-light group-hover:border-accent group-hover:bg-accent/10 transition-all duration-300">
            <span class="w-11 h-11 [&>svg]:w-full [&>svg]:h-full" set:html={svgMap[platform.icon]} />
          </div>
          <span class="text-xs tracking-wider uppercase max-w-[80px] text-center leading-tight">{platform.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>
