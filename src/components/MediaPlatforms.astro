---
import { PLATFORMS } from '../data/constants';
import { iconDefs } from '../data/icons';
---

<section id="music" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-xs tracking-[0.3em] uppercase text-accent mb-12 text-center">Listen</h2>

    <div class="flex flex-wrap justify-center gap-8 md:gap-16">
      {PLATFORMS.map(platform => (
        <a
          href={platform.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-3 text-text-dim hover:text-text transition-all duration-300"
        >
          <div class="w-16 h-16 flex items-center justify-center border border-border-light group-hover:border-accent group-hover:bg-accent/10 transition-all duration-300">
            <svg class="w-9 h-9" viewBox={iconDefs[platform.icon].viewBox} fill="currentColor">
              <path d={iconDefs[platform.icon].path} />
            </svg>
          </div>
          <span class="text-xs tracking-wider uppercase">{platform.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>
