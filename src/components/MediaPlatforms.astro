---
const platforms = [
  { name: 'Bandcamp', url: 'https://xweed420x.bandcamp.com/', icon: 'bandcamp' },
  { name: 'Spotify', url: 'https://open.spotify.com/artist/5UM6QbXYllW5ByF0umKJt1', icon: 'spotify' },
  { name: 'SoundCloud', url: 'https://soundcloud.com/weed420', icon: 'soundcloud' },
];
---

<section id="music" class="py-24 px-6 bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-xs tracking-[0.3em] uppercase text-[#dc2626] mb-12 text-center">Listen</h2>
    
    <div class="flex flex-wrap justify-center gap-8 md:gap-16">
      {platforms.map(platform => (
        <a 
          href={platform.url} 
          target="_blank" 
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-3 text-[#f5f5f5]/50 hover:text-[#f5f5f5] transition-all duration-300"
        >
          <div class="w-16 h-16 flex items-center justify-center border border-[#f5f5f5]/20 group-hover:border-[#dc2626] group-hover:bg-[#dc2626]/10 transition-all duration-300">
            {platform.icon === 'bandcamp' && (
              <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
                <path d="M0 18.75l7.437-13.5H24l-7.438 13.5H0z"/>
              </svg>
            )}
            {platform.icon === 'spotify' && (
              <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm9.05 17.59c-.24.36-.66.48-1.02.24-2.82-1.74-6.36-2.1-10.56-1.14-.42.12-.78-.18-.9-.54-.12-.42.18-.78.54-.9 4.56-1.02 8.52-.6 11.64 1.32.42.18.48.66.3 1.02zm1.44-3.3c-.3.42-.84.6-1.26.3-3.24-1.98-8.16-2.58-11.94-1.38-.48.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14C9.6 9.9 15 10.56 18.72 12.84c.36.18.54.78.24 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.2c-.6.18-1.16-.3-1.26-1.18-.06-.42.12-.84.72-1.02 4.56-1.2 10.44-1.44 14.82-1.44.42.06.78.32.96.78.18.42-.12.96-.5 1.02z"/>
              </svg>
            )}
            {platform.icon === 'soundcloud' && (
              <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
                <path d="M1.175 12.225c-.051 0-.094.046-.101.1l-.233 2.154.233 2.105c.007.058.05.098.101.098.05 0 .09-.04.099-.098l.255-2.105-.27-2.154c-.009-.06-.052-.1-.102-.1zm-.899.825c-.056 0-.102.05-.11.11l-.21 1.827.21 1.764c.008.063.054.11.11.11.054 0 .1-.047.108-.11l.24-1.764-.24-1.827c-.008-.06-.054-.11-.108-.11zm1.795-.539c-.063 0-.116.058-.126.126l-.192 1.795.192 1.734c.01.068.063.126.126.126.062 0 .115-.058.125-.126l.221-1.734-.221-1.795c-.01-.068-.063-.126-.125-.126zm.899-.263c-.07 0-.129.064-.14.14l-.172 1.684.172 1.636c.011.074.07.14.14.14.068 0 .127-.066.138-.14l.197-1.636-.196-1.684c-.011-.076-.07-.14-.139-.14zm.9-.322c-.077 0-.143.071-.155.154l-.153 1.573.153 1.531c.012.083.078.154.155.154.076 0 .142-.071.154-.154l.175-1.531-.175-1.573c-.012-.083-.078-.154-.154-.154zm.9-.245c-.084 0-.156.077-.169.169l-.135 1.462.135 1.402c.013.092.085.169.169.169.083 0 .155-.077.168-.169l.154-1.402-.154-1.462c-.013-.092-.085-.169-.168-.169zm.901-.182c-.092 0-.17.084-.183.183l-.116 1.351.116 1.308c.014.099.091.183.183.183.091 0 .168-.084.182-.183l.133-1.308-.133-1.351c-.014-.099-.091-.183-.182-.183zm.901-.126c-.099 0-.184.091-.197.197l-.098 1.241.098 1.194c.013.106.098.197.197.197.098 0 .183-.091.196-.197l.112-1.194-.112-1.241c-.013-.106-.098-.197-.196-.197zm.9-.077c-.107 0-.198.098-.212.212l-.079 1.129.079 1.103c.014.114.105.212.212.212.106 0 .197-.098.211-.212l.091-1.103-.091-1.129c-.014-.114-.105-.212-.211-.212zm.901-.034c-.114 0-.211.105-.226.226l-.061 1.019.061 1c.015.122.112.227.226.227.113 0 .21-.105.225-.227l.07-1-.07-1.019c-.015-.121-.112-.226-.225-.226z"/>
              </svg>
            )}
          </div>
          <span class="text-xs tracking-wider uppercase">{platform.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>