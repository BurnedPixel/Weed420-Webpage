---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'weed420 | Venezuelan Experimental Collective',
  description = 'Electronic experimental collective from Venezuela. Epic collage, hexd, deconstructed club. Amor de encava debuted #2 on RateYourMusic 2025.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="preload" href="/images/caracas-portrait.jpg" as="image" fetchpriority="high" />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>