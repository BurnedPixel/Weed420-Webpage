---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | weed420" description="This page does not exist.">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <h1 class="text-8xl md:text-9xl font-bold text-accent mb-6">404</h1>
    <p class="text-lg text-text-muted mb-2">Página no encontrada</p>
    <p class="text-sm text-text-dim mb-10 max-w-md">
      Esta página no existe o ha sido movida.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm tracking-wider uppercase text-text border border-border-light px-6 py-3 hover:bg-accent hover:border-accent transition-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      Volver al inicio
    </a>
  </main>
</Layout>
